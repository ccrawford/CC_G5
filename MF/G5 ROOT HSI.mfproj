        {
          "Source": {
            "SimConnectValue": {
              "UUID": "0",
              "Value": "(A:GPS DRIVES NAV1, Bool)\nif{\n  0\n}\nels{\n  (A:AUTOPILOT NAV SELECTED, Number) 1 ==\n  if{\n    (A:NAV HAS NAV:1, Bool)\n    if{\n      (A:NAV HAS LOCALIZER:1, Bool)\n      if{ 1 }\n      els{\n        (A:NAV TOFROM:1, Number) 0 !=\n        if{ 2 }\n        els{\n          (A:NAV HAS DME:1, Bool)\n          if{ 3 } els{ 10 }\n        }\n      }\n    }\n    els{ 7 }  // NAV1 detuned\n  }\n  els{\n    (A:NAV HAS NAV:2, Bool)\n    if{\n      (A:NAV HAS LOCALIZER:2, Bool)\n      if{ 4 }\n      els{\n        (A:NAV TOFROM:2, Number) 0 !=\n        if{ 5 }\n        els{\n          (A:NAV HAS DME:2, Bool)\n          if{ 6 } els{ 10 }\n        }\n      }\n    }\n    els{ 8 }  // NAV2 detuned\n  }\n}\n",
              "VarType": 2
            },
            "Type": "SimConnectSource"
          },
          "TestValue": {
            "type": 1,
            "Float64": 1.0,
            "String": null
          },
          "Device": {
            "Name": "CCs CC_G5 HSI",
            "CustomType": null,
