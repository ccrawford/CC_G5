        {
          "Source": {
            "SimConnectValue": {
              "UUID": "a00bbdba-ecad-4464-a410-cb85c260447b",
              "Value": "  (A:AUTOPILOT GLIDESLOPE ACTIVE, Bool) if{\n    (A:GPS DRIVES NAV1, Bool) if{ 7 } els{ 6 }\n  } els{\n    (A:AUTOPILOT ALTITUDE LOCK, Bool) if{ 1 } els{\n      (A:AUTOPILOT VERTICAL HOLD, Bool) if{ 2 } els{\n        (A:AUTOPILOT PITCH HOLD, Bool) if{ 3 } els{\n          (A:AUTOPILOT FLIGHT LEVEL CHANGE, Bool) if{ 4 } els{ 0 }\n        }\n      }\n    }\n  }\n",
              "VarType": 2
