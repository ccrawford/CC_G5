        {
          "Source": {
            "SimConnectValue": {
              "UUID": "0",
              "Value": "  (A:AUTOPILOT BANK HOLD, Bool) if{ 1 } els{\n    (A:AUTOPILOT HEADING LOCK, Bool) if{ 2 } els{\n      (A:AUTOPILOT BACKCOURSE HOLD, Bool) if{ 6 } els{\n        (A:AUTOPILOT NAV1 LOCK, Bool) if{\n          (A:GPS DRIVES NAV1, Bool) if{ 3 } els{\n            (A:NAV HAS LOCALIZER:1, Bool) if{ 5 } els{ 4 }\n          }\n        } els{\n          (A:AUTOPILOT APPROACH HOLD, Bool) if{\n            (A:GPS DRIVES NAV1, Bool) if{ 3 } els{ 5 }\n          } els{ 0 }\n        }\n      }\n    }\n  }",
              "VarType": 2
            },
            "Type": "SimConnectSource"
          },
          "TestValue": {
            "type": 1,
            "Float64": 1.0,
            "String": null
          },
          "Device": {
            "Name": "CCs CC_G5 PFD",
            "CustomType": null,
