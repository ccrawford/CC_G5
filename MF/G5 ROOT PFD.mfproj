            "MessageType": 66,
            "Value": "$",
            "Type": "CustomDevice"
          },
          "DeviceType": "CustomDevice",
          "DeviceName": "CCs CC_G5 PFD",
          "GUID": "3d8bf04e-0d0a-4ae3-8f81-843fad40aff7",
          "Active": true,
          "Name": "AP Lateral Mode Enumeration",
          "Type": "OutputConfigItem",
          "Controller": {
            "Name": "CC_G5 ESP32 PFD",
            "Serial": "SN-98A316E591C4"
          }
        },
        {
          "Source": {
            "SimConnectValue": {
              "UUID": "a72a02c3-8080-4655-9196-fedf99e47990",
              "Value": "(A:AUTOPILOT APPROACH HOLD, Bool) if{\n  (A:AUTOPILOT BACKCOURSE HOLD, Bool) if{ 6 } els{\n    (A:GPS DRIVES NAV1, Bool) if{ 3 } els{\n      (A:NAV HAS LOCALIZER:1, Bool) if{ 5 } els{ 4 }\n    }\n  }\n} els{\n  (A:AUTOPILOT NAV1 LOCK, Bool) if{\n    (A:AUTOPILOT HEADING LOCK, Bool) \n    (A:AUTOPILOT BANK HOLD, Bool) or\n    if{\n      (A:GPS DRIVES NAV1, Bool) if{ 3 } els{\n         (A:NAV HAS LOCALIZER:1, Bool) if{ 5 } els{ 4 }\n      }\n    } els{ 0 }\n  } els{ 0 }\n}",
              "VarType": 2
            },
            "Type": "SimConnectSource"
          },
          "TestValue": {
            "type": 1,
            "Float64": 1.0,
            "String": null
          },
          "Device": {
            "Name": "CCs CC_G5 PFD",
            "CustomType": null,
            "CustomName": "CCs CC_G5 PFD",
            "MessageType": 64,
            "Value": "$",
            "Type": "CustomDevice"
